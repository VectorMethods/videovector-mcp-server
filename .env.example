VIDEOVECTOR_API_KEY=<your-videovector-api-key>
VIDEOVECTOR_BASE_URL=https://api.vectormethods.com/api/v2
VIDEOVECTOR_TIMEOUT=90000
VIDEOVECTOR_MAX_RETRIES=3

# Optional self-hosted Streamable HTTP mode.
MCP_TRANSPORT_MODE=stdio
PORT=8080
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_ALLOWED_HOSTS=localhost,127.0.0.1
MCP_HTTP_ALLOWED_ORIGINS=
MCP_HTTP_MAX_SESSIONS=200
MCP_HTTP_ENABLE_JSON_RESPONSE=false
