{
  "schema_version": "1.0.0",
  "package": {
    "registry": "npm",
    "name": "@vectormethods/videovector-mcp-server",
    "tarball_command": "npm pack --dry-run"
  },
  "container": {
    "registry": "ghcr.io",
    "image": "ghcr.io/vectormethods/videovector-mcp-server",
    "dockerfile": "Dockerfile"
  },
  "release_inputs": [
    "src/**",
    "package.json",
    "package-lock.json",
    "tsconfig.json",
    "README.md",
    "docs/**",
    "examples/**",
    "artifacts/tool-contract.json"
  ]
}
